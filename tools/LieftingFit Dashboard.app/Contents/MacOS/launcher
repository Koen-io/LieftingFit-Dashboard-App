#!/bin/bash
# Opens Chrome on the LieftingFit dashboard, filling the screen with Chrome's
# tab strip and toolbar still visible.
#
# Why NOT any kind of fullscreen:
#   --start-fullscreen            -> hides the tab strip.
#   chrome.windows "fullscreen"   -> same.
#   AXFullScreen (green button)   -> macOS fullscreen, but Chrome then hides its
#                                    toolbar unless the per-profile setting
#                                    "Always Show Toolbar in Full Screen" is on,
#                                    which only the user can toggle.
#
# So instead: a NORMAL window sized to the whole screen, plus the macOS menubar
# set to auto-hide system-wide. Same result - no menubar, tabs visible - with
# nothing left for the trainer to configure.
EXT_ID="odppaoogblejdfldnlfacbeiomckheej"
URL="chrome-extension://${EXT_ID}/index.html"

open -na "Google Chrome" --args --new-window "$URL"

# Wait for the window, then size it to the full screen. Chrome's own scripting
# does this - no Accessibility permission needed, unlike AXFullScreen.
for i in $(seq 1 40); do
  if osascript -e 'tell application "Google Chrome" to count windows' 2>/dev/null | grep -qv '^0$'; then
    break
  fi
  sleep 0.25
done
sleep 0.6

osascript <<'APPLESCRIPT' 2>/dev/null
set {sw, sh} to {0, 0}
tell application "Finder" to set {_a, _b, sw, sh} to bounds of window of desktop
tell application "Google Chrome"
  repeat with w in windows
    try
      if title of active tab of w contains "Trainer Dashboard" then
        set bounds of w to {0, 0, sw, sh}
        exit repeat
      end if
    end try
  end repeat
end tell
APPLESCRIPT
